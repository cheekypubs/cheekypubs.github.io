---
layout: null
---
[
  {% for story in site.stories %}
  {% assign effective_art_image = story.art_image %}
  {% assign effective_art_alt = story.art_alt %}
  {% assign effective_art_caption = story.art_caption %}
  {% if story.story_id and (effective_art_image == blank or effective_art_alt == blank or effective_art_caption == blank) %}
    {% assign series_chapters = site.stories | where: "story_id", story.story_id | sort: "chapter" %}
    {% for ch in series_chapters %}
      {% if ch.art_image and ch.art_image != blank %}
        {% if effective_art_image == blank %}
          {% assign effective_art_image = ch.art_image %}
        {% endif %}
        {% if effective_art_alt == blank %}
          {% assign effective_art_alt = ch.art_alt %}
        {% endif %}
        {% if effective_art_caption == blank %}
          {% assign effective_art_caption = ch.art_caption %}
        {% endif %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}
  {
    "title": {{ story.title | jsonify }},
    "author": {{ story.author | jsonify }},
    "url": {{ story.url | absolute_url | jsonify }},
    "slug": {{ story.path | remove_first: "_stories/" | split: "." | first | jsonify }},
    "date": {{ story.date | date: "%Y-%m-%d" | jsonify }},
    "story_id": {{ story.story_id | jsonify }},
    "chapter": {{ story.chapter | default: nil | jsonify }},
    "chapter_title": {{ story.chapter_title | jsonify }},
    "description": {{ story.description | jsonify }},
    "art_image": {{ effective_art_image | jsonify }},
    "art_alt": {{ effective_art_alt | jsonify }},
    "art_caption": {{ effective_art_caption | jsonify }},
    "tags": {{ story.tags | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
